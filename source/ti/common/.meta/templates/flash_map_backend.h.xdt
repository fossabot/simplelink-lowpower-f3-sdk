%%{
/*
 *  ======== flash_map_backend.h.xdt ========
 */
 
    var module = system.modules['/ti/common/mcuboot'];
    var inst = module.$static;

    // included to see if secure secondary bootloader has been enabled
    let CCFG = system.modules["/ti/devices/CCFG"];

%%}
/*
 *  ======== flash_map_backend.h ========
 *  Configuration File for MCUboot
 *
 *  DO NOT EDIT - This file is generated by the SysConfig tool.
 *
 */
#ifndef __FLASH_MAP_BACKEND_H__
#define __FLASH_MAP_BACKEND_H__

#include "flash_map_backend/flash_map.h"

#include "mcuboot_config.h"
#define FLASH_DEVICE_INDEX_MASK                 (0x7F)
#define FLASH_DEVICE_GET_EXT_INDEX(n)           ((n) & FLASH_DEVICE_INDEX_MASK)
#define FLASH_DEVICE_EXTERNAL_FLAG              (0x80)
#define FLASH_DEVICE_INTERNAL_FLASH             (0x7F)
#define FLASH_DEVICE_EXTERNAL_FLASH(index)      (FLASH_DEVICE_EXTERNAL_FLAG | index)

#ifndef TI_BOOT_EXTERNAL_DEVICE_INDEX
/* assume first(one) SMIF device is used */
#define TI_BOOT_EXTERNAL_DEVICE_INDEX            (0)
#endif

/*
* The following definitions apply for the configuration in which
* TI_BOOT_USE_EXTERNAL_FLASH is not defined; that is, both
* Primary and Secondary slots are located in on-chip memory.
*/
% if ((CCFG != undefined ) && CCFG.$static.ssbEnabled === true) {
#define BOOTLOADER_BASE_ADDRESS         0x`inst.bootloaderBaseAddress.toString(16)` + 0x`CCFG.$static.hdrSize.toString(16)`
#define BOOT_BOOTLOADER_SIZE            0x`inst.bootloaderSize.toString(16)` - 0x`CCFG.$static.hdrSize.toString(16)`
% } else {
#define BOOTLOADER_BASE_ADDRESS         0x`inst.bootloaderBaseAddress.toString(16)`
#define BOOT_BOOTLOADER_SIZE            0x`inst.bootloaderSize.toString(16)`
% }

#define BOOT_PRIMARY_1_BASE_ADDRESS     0x`inst.primaryBase1.toString(16)`
#define BOOT_PRIMARY_1_SIZE             0x`inst.primarySize1.toString(16)`

#define BOOT_SECONDARY_1_BASE_ADDRESS   0x`inst.secondaryBase1.toString(16)`
#define BOOT_SECONDARY_1_SIZE           0x`inst.secondarySize1.toString(16)`

% if (inst.tzEnabled === true)
% {
#define BOOT_PRIMARY_2_BASE_ADDRESS     0x`inst.primaryBase2.toString(16)`
#define BOOT_PRIMARY_2_SIZE             0x`inst.primarySize2.toString(16)`

#define BOOT_SECONDARY_2_BASE_ADDRESS   0x`inst.secondaryBase2.toString(16)`
#define BOOT_SECONDARY_2_SIZE           0x`inst.secondarySize2.toString(16)`
% }


#endif /* __FLASH_MAP_BACKEND_H__ */
