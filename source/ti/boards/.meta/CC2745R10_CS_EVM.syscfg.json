/*
 *  ======== CC2745R10_CS_EVM.syscfg.json ========
 */
 {
    "name": "CC2745R10_CS_EVM",
    "displayName": "CC2745R10-CS-EVM Development Platform",
    "device": "CC2745R10RHAQ1",
    "part": "Default",
    "package": "RHA",
    "headers": [
        {
            "type": "CAN FD Header",
            "name": "can_fd_header",
            "displayName": "CAN FD Header",
            "dimensions": {
                "columns": [
                    {
                        "top": 1,
                        "bottom": 2
                    }
                ]
            },
            "pins": [
                {
                    "number": 1,
                    "name": "CANL"
                },
                {
                    "number": 2,
                    "name": "CANH"
                }
            ]
        },
        {
            "type": "UART Header",
            "name": "uart_header",
            "displayName": "UART Header",
            "dimensions": {
                "columns": [
                    {
                        "top": 1,
                        "bottom": 2
                    }
                ]
            },
            "pins": [
                {
                    "number": 1,
                    "name": "DIO1",
                    "ball": "4",
                    "preferredType": [
                        "UART_TXD"
                    ]
                },
                {
                    "number": 2,
                    "name": "DIO2",
                    "ball": "5",
                    "preferredType": [
                        "UART_RXD"
                    ]
                }
            ]
        },
        {
            "type": "SPI Header",
            "name": "spi_header",
            "displayName": "SPI Header",
            "dimensions": {
                "columns": [
                    {
                        "top": 1,
                        "bottom": 4
                    }
                ]
            },
            "pins": [
                {
                    "number": 1,
                    "name": "DIO3",
                    "ball": "6",
                    "preferredType": [
                        "SPI_SCLK"
                    ]
                },
                {
                    "number": 2,
                    "name": "DIO4",
                    "ball": "7",
                    "preferredType": [
                        "SPI_POCI"
                    ]
                },
                {
                    "number": 3,
                    "name": "DIO5",
                    "ball": "8",
                    "preferredType": [
                        "SPI_PICO"
                    ]
                },
                {
                    "number": 4,
                    "name": "DIO7",
                    "ball": "10",
                    "preferredType": [
                        "SPI_CSN"
                    ]
                }
            ]
        },
        {
            "type": "Power Supply Header",
            "name": "power_supply_header",
            "displayName": "Power Supply Header",
            "dimensions": {
                "columns": [
                    {
                        "top": 1,
                        "bottom": 3
                    }
                ]
            },
            "pins": [
                {
                    "number": 1,
                    "name": "12V"
                },
                {
                    "number": 2,
                    "name": "GND"
                },
                {
                    "number": 3,
                    "name": "WMCU_VDD"
                }
            ]
        },
        {
            "type": "On-board Test Points",
            "name": "on_board_test_points",
            "displayName": "On-board Test Points",
            "dimensions": {
                "columns": [
                    {
                        "top": 1,
                        "bottom": 3
                    }
                ]
            },
            "pins": [
                {
                    "number": 1,
                    "name": "DIO19",
                    "ball": "21"
                },
                {
                    "number": 2,
                    "name": "DIO20",
                    "ball": "22"
                },
                {
                    "number": 3,
                    "name": "GND"
                }
            ]
        }
    ],
    "components": {
        "LED_RED": {
            "displayName": "LaunchPad LED Red",
            "definition": "/ti/boards/components/led_dimmable.json",
            "connections": {
                "OUTPUT": "16" // DIO16
            }
        },
        "LED_GREEN": {
            "displayName": "LaunchPad LED Green",
            "definition": "/ti/boards/components/led_dimmable.json",
            "connections": {
                "OUTPUT": "14" // DIO12
            }
        },
        /* symbolic links/aliases for LED portability between LaunchPads */
        "LED": {
            "link": "LED_RED"
        },
        "LED_DIMMABLE": {
            "link": "LED_GREEN"
        },
        "LED0": {
            "link": "LED_RED"
        },
        "LED1": {
            "link": "LED_GREEN"
        },
        "LED0_PWM": {
            "link": "LED0"
        },
        "LED1_PWM": {
            "link": "LED1"
        },

        "CAN_BUS": {
            "displayName": "On-board CAN Bus",
            "description": "On-board CAN Bus connected to TCAN340x CAN FD Transceiver",
            "longDescription": "The on-board CAN bus is connected to the TCAN340x CAN FD transceiver.",
            "definition": "/ti/boards/components/can.json",
            "connections": {
                "RX": "20", // DIO18
                "TX": "19"  // DIO17
            }
        },
        "TCAN340x": {
            "displayName": "TCAN340x CAN Transceiver",
            "description": "TCAN340x Controller Area Network (CAN) FD Transceiver",
            "longDescription": "TCAN340x Controller Area Network (CAN) FD Transceiver",
            "definition": "/ti/boards/components/tcan340x.json",
            "connections": {
                "STB": "15", // DIO15
                "SHDN": "13"  // DIO11
            },
            "subComponents": {
                "CAN": {
                    "link": "CAN_BUS"
                }
            }
        },
        "SPI_BUS": {
            "displayName": "On-board SPI Bus",
            "description": "On-board Bus connected to SPI header",
            "longDescription": "On-board Bus connected to SPI header",
            "definition": "/ti/boards/components/spiBus.json",
            "connections": {
                "SCLK": "6", // DIO3
                "PICO": "8", // DIO5
                "POCI": "7"  // DIO4
            }
        },
        "SPI": {
            "displayName": "On-board SPI Bus with Chip Select",
            "description": "On-board SPI Bus with Chip Select connected to SPI header",
            "longDescription": "On-board SPI Bus with Chip Select connected to SPI header",
            "definition": "/ti/boards/components/spiDevice.json",
            "subComponents": {
                "SPI": {
                    "link": "SPI_BUS"
                },
                "SELECT": {
                    "displayName": "On-board SPI Bus Chip Select",
                    "description": "On-board SPI Bus Chip Select connected to SPI header",
                    "longDescription": "On-board SPI Bus Chip Select connected to SPI header",
                    "connections": {
                        "CSN": "10" // DIO7
                    }
                }
            }
        },
        "UART": {
            "displayName": "On-board UART",
            "description": "On-board UART connected to UART header",
            "longDescription": "On-board UART connected to UART header",
            "definition": "/ti/boards/components/uart.json",
            "connections": {
                "RXD": "5", // DIO2
                "TXD": "4"  // DIO1
            }
        },
        /* symbolic links/aliases for UART portability for examples made for LaunchPads */
        "XDS110UART": {
            "link": "UART"
        },
        "HFXT" : {
            "definition": "/ti/boards/components/crystal_tz3908aaa043.json",
            "settings": {
                "overrideCapArray": true,
                "hfxtCapArrayQ1" : 33,
                "hfxtCapArrayQ2" : 33
            }
        },
        "PE423211A-Z": {
            "type"        : "RF",
            "displayName" : "PE423211A-Z RF Antenna Switch",
            "description" : "PE423211A-Z RF Antenna Switch",
            "signals": {
                "V1": {"type": "RF_V1", "connection": 24}, // DIO 22
                "V2": {"type": "RF_V2", "connection": 23}  // DIO 21
            }
        },

        "RF" : {
            "link": "PE423211A-Z"
        }

    }
}