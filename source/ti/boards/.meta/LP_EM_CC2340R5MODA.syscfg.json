/*
 *  ======== LP_EM_CC2340R5MODA.syscfg.json ========
 *
 */
 {
    "name": "LP_EM_CC2340R5MODA",
    "displayName": "CC2340R5MODA Development Platform",
    "gpn": "CC2340R5MODA",
    "pkg": "MOD (MHA)",
    "headers": [
        {
            "type": "BoosterPack 40 pin",
            "default": true,
            "name": "boosterpack",
            "displayName": "BoosterPack Standard Header",
            "dimensions": {
                "columns": [
                    { "top":  1, "bottom": 10 },
                    { "top": 21, "bottom": 30 },

                    { "blank": true },

                    { "top": 40, "bottom": 31 },
                    { "top": 20, "bottom": 11 }
                ]
            },
            "pins": [
                {
                    "number" : 1,
                    "name"   : "3V3"
                },
                {
                    "number" : 2,
                    "name"   : "NC"
                },
                {
                    "number": 3,
                    "ball": "17",
                    "name": "DIO20",
                    "preferredType": ["UART_RXD"]
                },
                {
                    "number": 4,
                    "ball": "9",
                    "name": "DIO6",
                    "preferredType": ["UART_TXD"]
                },
                {
                    "number": 5,
                    "ball": "13",
                    "name": "DIO4"
                },
                {
                    "number": 6,
                    "name": "NC"
                },
                {
                    /* SPI SCLK: Can be connected to DIO18 by connecting pins 3 and 5 on header P6  */
                    "number": 7,
                    "name": "NC"
                },
                {
                    "number": 8,
                    "ball": "12",
                    "name": "DIO3"
                },
                {
                    /* I2C SCL: Can be connected to DIO24 by connecting pins 2 and 4 on header P6 */
                    "number": 9,
                    "name": "NC"
                },
                {
                    /* I2C SDA: Can be connected to DIO8 by conencting pins 3 and 5 on header P2 */
                    "number": 10,
                    "name": "NC"
                },

                {
                    "number": 11,
                    "name": "NC"
                },
                {
                    "number": 12,
                    "ball": "11",
                    "name": "DIO24"
                },
                {
                    "number": 13,
                    "ball": "16",
                    "name": "DIO18"
                },
                {
                    /* SPI POCI: Can be connected to DIO21 by connecting pins 2 and 4 on header P2 */
                    "number": 14,
                    "name": "NC"
                },
                {
                    "number": 15,
                    "ball": "18",
                    "name": "DIO12"
                },
                {
                    "number" : 16,
                    "name"   : "LPRST"
                },
                {
                    "number": 17,
                    "name": "NC"
                },
                {
                    /* Can be connected to DIO11 by placing R19 and removing R20*/
                    "number": 18,
                    "name": "NC"
                },
                {
                    "number": 19,
                    "name": "NC"
                },
                {
                    "number" : 20,
                    "name"   : "GND"
                },

                {
                    "number" : 21,
                    "name"   : "5V"
                },
                {
                    "number" : 22,
                    "name"   : "GND"
                },
                {
                    "number": 23,
                    "name": "NC"
                },
                {
                    "number": 24,
                    "name": "NC"
                },
                {
                    "number": 25,
                    "name": "NC"
                },
                {
                    "number": 26,
                    "name": "NC"
                },
                {
                    "number": 27,
                    "name": "NC"
                },
                {
                    "number": 28,
                    "name": "NC"
                },
                {
                    "number" : 29,
                    "name"   : "NC"
                },

                {
                    "number" : 30,
                    "name"   : "NC"
                },
                {
                    "number" : 31,
                    "name"   : "NC"
                },
                {
                    "number" : 32,
                    "name"   : "NC"
                },
                {
                    "number" : 33,
                    "name"   : "SWDCK"
                },
                {
                    "number" : 34,
                    "name"   : "SWDIO"
                },
                {
                    "number" : 35,
                    "name"   : "BPRST"
                },
                {
                    "number": 36,
                    "name": "NC"
                },
                {
                    "number": 37,
                    "name": "NC"
                },
                {
                    "number": 38,
                    "ball": "21",
                    "name": "DIO11"
                },
                {
                    "number": 39,
                    "ball": "15",
                    "name": "DIO21"
                },
                {
                    "number": 40,
                    "ball": "10",
                    "name": "DIO8"
                }
            ]
        }
    ],
    "components": {
        "LED_RED": {
            "displayName" : "LaunchPad LED Red",
            "definition"  : "/ti/boards/components/led_dimmable.json",
            "connections" : {
                "OUTPUT": "15" /* DIO21, BP.39 */
            }
        },
        "LED_GREEN": {
            "displayName" : "LaunchPad LED Green",
            "definition"  : "/ti/boards/components/led_dimmable.json",
            "connections" : {
                "OUTPUT": "10" /*  DIO8, BP.40*/
            }
        },

        /* Symbolic links/aliases for LED portability between LaunchPads */
        "LED": {
            "link" : "LED_RED"
        },
        "LED_DIMMABLE": {
            "link" : "LED_GREEN"
        },
        "LED0": {
            "link": "LED_RED"
        },
        "LED1": {
            "link": "LED_GREEN"
        },
        "LED0_PWM" : {
            "link" : "LED0"
        },
        "LED1_PWM" : {
            "link" : "LED1"
        },

        "BTN-1": {
            "displayName" : "LaunchPad Button BTN-1 (Left)",
            "definition"  : "/ti/boards/components/button.json",
            "longDescription" : "BTN-1 (Left) LaunchPad button with no external pull.",
            "settings": {
                "DIN": {
                    "pull": "Internal",
                    "polarity": "Active Low"
                }
            },
            "connections" : {
                "INPUT": "16" /* DIO18, BP.13, requires header P6 pins 5 and 6 to be jumpered */
            }
        },
        "BTN-2": {
            "displayName" : "LaunchPad Button BTN-2 (Right)",
            "definition"  : "/ti/boards/components/button.json",
            "longDescription" : "BTN-2 (Right) LaunchPad button with no external pull.",
            "settings": {
                "DIN": {
                    "pull": "Internal",
                    "polarity": "Active Low"
                }
            },
            "connections" : {
                "INPUT": "11" /* DIO24, BP.12, requires header P6 pins 2 and 1 to be jumpered*/
            }
        },

        /* Symbolic links/aliases for BUTTON portability between LaunchPads */
        "BUTTON0": {
            "link": "BTN-1"
        },
        "BUTTON1": {
            "link": "BTN-2"
        },

        "LP_SPI_BUS": {
            "displayName" : "LaunchPad SPI Bus",
            "description" : "Standard BoosterPack header SPI",
            "longDescription" : "Standard BoosterPack header SPI",
            "definition"  : "/ti/boards/components/spiBus.json",
            "connections" : {
                "SCLK": "16",  /* DIO 18, BP.7, requires header P6 pins 5 and 3 to be jumpered */
                "PICO": "18",  /* DIO 12, BP.15 */
                "POCI": "15"   /* DIO 21, BP.14, requires header P2 pins 2 and 4 to be jumpered */
            }
        },

        "LP_SPI": {
            "displayName" : "LaunchPad SPI Bus with Chip Select",
            "description" : "Standard BoosterPack header SPI with Chip Select",
            "longDescription" : "Standard BoosterPack header SPI with Chip Select",
            "definition"  : "/ti/boards/components/spiDevice.json",
            "subComponents": {
                "SPI": {
                    "link": "LP_SPI_BUS"
                },
                "SELECT": {
                    "displayName" : "LaunchPad SPI Bus Chip Select",
                    "description" : "Standard BoosterPack header SPI Chip Select",
                    "longDescription" : "Standard BoosterPack header SPI Chip Select",
                    "connections" : {
                        "CSN": "21" /* DIO11, BP.18, requires R19 to be mounted */
                    }
                }
            }
        },

        "MX25R8035F": {
            "displayName" : "MX25R8035F SPI Flash",
            "description" : "MX25R8035F ultra low power, 8Mb CMOS serial multi I/O SPI flash memory",
            "longDescription": "[__MX25R8035F__](https://www.macronix.com/en-us/products/NOR-Flash/Serial-NOR-Flash/Pages/spec.aspx?p=MX25R8035F&m=Serial+NOR+Flash&n=PM2164) is a 8Mb serial NOR flash memory, which is configured as 1,048,576 x 8 internally. When it is in four I/O mode, the structure becomes 2,097,152 bits x 4 or 4,194,304 bits x 2.",
            "definition"  : "/ti/boards/components/spi25xFlash.json",
            "settings" : {
                "capacity" : 1048576
            },
            "subComponents": {
                "SPI": {
                    "link": "LP_SPI_BUS"
                },
                "SELECT": {
                    "displayName" : "MX25R8035F SPI Flash Chip Select",
                    "description" : "MX25R8035F SPI Flash Chip Select",
                    "longDescription" : "MX25R8035F SPI flash Chip Select",
                    "definition"  : "/ti/boards/components/spiSelect.json",
                    "connections" : {
                        "CSN": "21" /* DIO11, BP.38 */
                    }
                }
            }
        },

        "SPI_FLASH" : {
            "link": "MX25R8035F"
        },

        "XDS110UART": {
            "definition": "/ti/boards/components/xds110Uart.json",
            "connections": {
                "RXD": "17", /* DIO20, BP.3 */
                "TXD": "9"   /* DIO6, BP.4 */
            }
        }
    }
}