"{{SDK_DIR}}/tools/common/mcuboot/imgtool" sign --header-size 0x100 --align 4 --slot-size `slotSize` --version `v1` `padding` --key "{{SDK_DIR}}/`keyPath`" "{{BUILD_DIR}}/{{BASE_NAME}}_noheader.bin" "{{BUILD_DIR}}/{{BASE_NAME}}_v1.bin"
%       if (v2 && v2.trim() !== "") {
"{{SDK_DIR}}/tools/common/mcuboot/imgtool" sign --header-size 0x100 --align 4 --slot-size `slotSize` --version `v2` `padding` --key "{{SDK_DIR}}/`keyPath`" "{{BUILD_DIR}}/{{BASE_NAME}}_noheader.bin" "{{BUILD_DIR}}/{{BASE_NAME}}_v2.bin"
