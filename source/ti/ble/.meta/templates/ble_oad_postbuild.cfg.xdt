%%{
/*
 *  ======== ti_ble_oad_postbuild.cfg ========
 *  OAD Post-Build Command File
 *
 *  DO NOT EDIT - This file is generated by the SysConfig tool.
 *
 *  Contains shell commands to be executed by oad_postbuild_runner after a
 *  successful build.  The runner substitutes the following placeholders with
 *  values supplied on its command line:
 *
 *    {{CG_TOOL_ROOT}}  - Compiler root (TI-Clang CG_TOOL_ROOT or IAR TOOLKIT_DIR)
 *    {{BUILD_DIR}}      - Build output directory
 *    {{BASE_NAME}}      - Build artifact base name (without extension)
 *    {{SDK_DIR}}         - SDK installation directory
 *
 *  Lines starting with '#' are comments and are ignored by the runner.
 *  Empty lines are ignored.
 */

let generateContent = false;
let oadMethod = "NONE";
let isIAR = (system.compiler === "iar");
let msOadHalfModeBuild = false;

let bleMod = system.modules["/ti/ble/ble"];
if (bleMod) {
    let ble = bleMod.$static;
    if (ble.enableOad) {
        /* Persistent OAD checked first â€” mirrors updateOadVisibility() priority */
        if (ble.enablePersistentOad) {
            oadMethod = "PERSISTENT";
            generateContent = true;
        }
        else if (ble.oadMethod !== "NONE") {
            oadMethod = ble.oadMethod;
            generateContent = true;

            if (ble.oadMethod === "MULTISTEP_OAD") {
                msOadHalfModeBuild = ble.halfModeBuild;
            }
        }
    }
}
%%}
# OAD Post-Build Commands - Generated by SysConfig
# OAD Method: `oadMethod`
# Compiler: `isIAR ? "iar" : "ticlang"`
